FROM node:20-slim

# Install OpenSSL for Prisma
RUN apt-get update -y && apt-get install -y openssl

WORKDIR /app

# Copy package files
COPY package.json ./

# Install dependencies (ignoring any existing Windows node_modules and lockfiles)
RUN npm install --legacy-peer-deps

# Copy Prisma schema
COPY prisma ./prisma/

# Generate Prisma Client (Linux bindings)
RUN npx prisma generate

# Copy the rest of the application code
# (We will use volumes in docker-compose to override this, but it's good practice)
COPY . .

EXPOSE 3000

CMD ["npm", "run", "dev"]
