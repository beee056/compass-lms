generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id        String           @id
  name      String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  users     User[]
  students  StudentProfile[]
  templates TaskTemplate[]
  logs      ActivityLog[]
}

model User {
  id             String          @id
  clerkId        String          @unique
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  role           String          @default("MENTOR") // "STUDENT", "MENTOR", "ADMIN"
  name           String
  email          String          @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  studentProfile StudentProfile?
}

model StudentProfile {
  id             String       @id
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  name           String
  phase          String       // e.g., "自己分析", "書類作成"
  driveFolderId  String?      // Google Drive連携用の生徒固有フォルダID
  driveFolderUrl String?      // Google Driveフォルダへの直リンク
  highSchool     String?      // 高校名
  grade          String?      // 学年
  phone          String?      // 電話番号
  parentEmail    String?      // 保護者メールアドレス
  studentEmail   String?      @unique // 生徒招待・ログイン用メアド
  userId         String?      @unique // サインアップ後に紐づくUser ID
  user           User?        @relation(fields: [userId], references: [id])
  status         String       @default("ACTIVE") // "ACTIVE" (在籍生) / "ARCHIVED" (卒業生)
  universities   University[]
  tasks          Task[]
  milestones     Milestone[]
  documents      Document[]
  practiceRecords PracticeRecord[]
  stepAnswers    StepAnswer[]
  logs           ActivityLog[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model University {
  id               String         @id
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  name             String
  department       String
  method           String       // e.g., "総合型選抜"
  milestones       Milestone[]
  tasks            Task[]
}

model Milestone {
  id               String         @id
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  universityId     String?
  university       University?    @relation(fields: [universityId], references: [id], onDelete: Cascade)
  title            String
  date             DateTime
  status           String         // "TODO", "DONE"
  type             String         // "書類提出", "面接"
}

model Task {
  id               String         @id
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  universityId     String?
  university       University?    @relation(fields: [universityId], references: [id], onDelete: Cascade)
  title            String
  dueDate          DateTime?
  completed        Boolean        @default(false)
  type             String         // "DOCUMENT", "TODO"
  progress         Int            @default(0) // 0-100% for documents
  isSelfCreated    Boolean        @default(false) // 生徒自身が作成したタスクかどうか
  comments         TaskComment[]
}

model TaskComment {
  id         String   @id
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id])
  content    String
  authorId   String   // userId (メンターまたは生徒)
  authorName String   // キャッシュ用（API呼び出しを減らすため）
  createdAt  DateTime @default(now())
}

model TaskTemplate {
  id        String         @id
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  name      String         // "早慶 総合型", "指定校推薦" など
  items     TemplateItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model TemplateItem {
  id         String       @id
  templateId String
  template   TaskTemplate @relation(fields: [templateId], references: [id])
  title      String
  type       String       // "TODO", "DOCUMENT"
  daysOffset Int          // 追加日からの相対日数（例: 7日後）
}

model ActivityLog {
  id               String          @id
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  studentProfileId String?
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id])
  action           String          // "TASK_COMPLETED", "DOCUMENT_ADDED", "COMMENT_ADDED"
  details          String          // 内容の説明
  createdAt        DateTime        @default(now())
}

model Document {
  id               String         @id
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  title            String
  url              String?        // Google Docs/Drive url
  type             String         // "志望理由書", "活動報告書", "その他"
  dueDate          DateTime?      // 提出期限（提出年月日）
  content          String?        @db.Text
  isInternal       Boolean        @default(false)
  isArchived       Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model PracticeRecord {
  id               String         @id
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  type             String         // "小論文", "志望理由書"
  prompt           String         // 設問
  answer           String         // 生徒の解答
  score            Int?           // AI採点スコア
  feedback         String         // AIフィードバック
  createdAt        DateTime       @default(now())
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  lessons     Lesson[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lesson {
  id          String       @id @default(cuid())
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  content     String       @db.Text
  order       Int          @default(0)
  steps       LessonStep[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model LessonStep {
  id          String       @id @default(cuid())
  lessonId    String
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title       String       
  description String       @db.Text 
  prompt      String       @db.Text 
  hint        String?      @db.Text
  placeholder String?      @db.Text
  order       Int          @default(0)
  isRequired  Boolean      @default(true)
  answers     StepAnswer[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model StepAnswer {
  id               String          @id @default(cuid())
  stepId           String
  step             LessonStep      @relation(fields: [stepId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile  @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  content          String          @db.Text
  feedbacks        AIFeedback[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model AIFeedback {
  id           String     @id @default(cuid())
  stepAnswerId String
  stepAnswer   StepAnswer @relation(fields: [stepAnswerId], references: [id], onDelete: Cascade)
  content      String     @db.Text 
  score        Int?       
  createdAt    DateTime   @default(now())
}

model QuestionBank {
  id          String   @id @default(cuid())
  category    String   
  title       String
  prompt      String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
