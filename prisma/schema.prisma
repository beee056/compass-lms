generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id               String           @id @default(cuid())
  name             String
  // PENDING(承認待ち) / ACTIVE / SUSPENDED(停止)。既存テナントはACTIVE
  status           String           @default("ACTIVE")
  approvedAt       DateTime?
  approvedByUserId String?
  // Clerk→Better Auth 移行用: 再登録時に既存ワークスペースを再取得するためのオーナーメール。
  // 一意制約により、並行プロビジョニング時のテナント重複作成を防ぐ（1オーナー=1ワークスペース）
  ownerEmail       String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  users            User[]
  students         StudentProfile[]
  templates        TaskTemplate[]
  logs             ActivityLog[]
}

model User {
  id             String          @id @default(cuid())
  // 旧Clerk識別子。移行期間中は残置し、完全移行後に削除する（nullable化済み）
  clerkId        String?         @unique
  // Better Auth のテナント紐付け。プロビジョニング前は一時的にnull
  tenantId       String?
  tenant         Tenant?         @relation(fields: [tenantId], references: [id])
  role           String          @default("MENTOR") // "STUDENT", "MENTOR", "ADMIN"
  // 運営者フラグ。環境変数OPERATOR_EMAILSと同期され、/admin配下でのみ横断権限が効く
  isOperator     Boolean         @default(false)
  name           String
  email          String          @unique
  // Better Auth 必須フィールド
  emailVerified  Boolean         @default(false)
  image          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  // 生徒本人のログインアカウント（1:1）
  studentProfile StudentProfile? @relation("StudentLogin")
  // Better Auth リレーション
  sessions       Session[]
  accounts       Account[]

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// Better Auth 管理テーブル（session / account / verification）
// ---------------------------------------------------------------------------
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?   @db.Text // email/password のハッシュ
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model StudentProfile {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  name           String
  phase          String       // e.g., "自己分析", "書類作成"
  driveFolderId  String?      // Google Drive連携用の生徒固有フォルダID
  driveFolderUrl String?      // Google Driveフォルダへの直リンク
  highSchool     String?      // 高校名
  grade          String?      // 学年
  phone          String?      // 電話番号
  parentEmail    String?      // 保護者メールアドレス
  studentEmail   String?      @unique // 生徒招待・ログイン用メアド
  userId         String?      @unique // サインアップ後に紐づくUser ID
  user           User?        @relation("StudentLogin", fields: [userId], references: [id])
  status         String       @default("ACTIVE") // "ACTIVE" (在籍生) / "ARCHIVED" (卒業生)
  universities   University[]
  tasks          Task[]
  milestones     Milestone[]
  documents      Document[]
  practiceRecords PracticeRecord[]
  stepAnswers    StepAnswer[]
  logs           ActivityLog[]
  sharedTokens   SharedAccessToken[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

model University {
  id               String         @id @default(cuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  name             String
  department       String
  method           String       // e.g., "総合型選抜"
  milestones       Milestone[]
  tasks            Task[]

  @@index([studentProfileId])
}

model Milestone {
  id               String         @id @default(cuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  universityId     String?
  university       University?    @relation(fields: [universityId], references: [id], onDelete: Cascade)
  title            String
  date             DateTime
  status           String         // "TODO", "DONE"
  type             String         // "書類提出", "面接"

  @@index([studentProfileId])
  @@index([universityId])
}

model Task {
  id               String         @id @default(cuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  universityId     String?
  university       University?    @relation(fields: [universityId], references: [id], onDelete: Cascade)
  title            String
  dueDate          DateTime?
  completed        Boolean        @default(false)
  type             String         // "DOCUMENT", "TODO"
  progress         Int            @default(0) // 0-100% for documents
  isSelfCreated    Boolean        @default(false) // 生徒自身が作成したタスクかどうか
  // 演習課題の割当元（問題バンク）。該当問題の添削提出で自動完了する
  questionBankId   String?
  questionBank     QuestionBank?  @relation(fields: [questionBankId], references: [id], onDelete: SetNull)
  comments         TaskComment[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt

  @@index([studentProfileId, completed, dueDate])
  @@index([studentProfileId, questionBankId])
  @@index([universityId])
}

model TaskComment {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  content    String
  authorId   String   // userId (メンターまたは生徒)
  authorName String   // キャッシュ用（API呼び出しを減らすため）
  authorRole String   @default("MENTOR") // "STUDENT" / "MENTOR" — 要返信バッジ判定用
  createdAt  DateTime @default(now())

  @@index([taskId])
}

model TaskTemplate {
  id        String         @id @default(cuid())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  name      String         // "早慶 総合型", "指定校推薦" など
  items     TemplateItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([tenantId])
}

model TemplateItem {
  id         String       @id @default(cuid())
  templateId String
  template   TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title      String
  type       String       // "TODO", "DOCUMENT"
  daysOffset Int          // 追加日からの相対日数（例: 7日後）

  @@index([templateId])
}

model ActivityLog {
  id               String          @id @default(cuid())
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  studentProfileId String?
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  action           String          // "TASK_COMPLETED", "DOCUMENT_ADDED", "COMMENT_ADDED"
  details          String          // 内容の説明
  createdAt        DateTime        @default(now())

  @@index([tenantId, createdAt])
  @@index([studentProfileId])
}

model Document {
  id               String         @id @default(cuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  title            String
  url              String?        // Google Docs/Drive url
  type             String         // "志望理由書", "活動報告書", "その他"
  dueDate          DateTime?      // 提出期限（提出年月日）
  content          String?        @db.Text
  isInternal       Boolean        @default(false)
  isArchived       Boolean        @default(false)
  status           String         @default("DRAFT") // "DRAFT"(下書き) "SUBMITTED"(生徒提出済) "REVIEWING"(レビュー中) "DONE"(完了)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([studentProfileId, isArchived])
}

model PracticeRecord {
  id               String         @id @default(cuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  type             String         // "小論文", "志望理由書"
  prompt           String         // 設問
  answer           String         // 生徒の解答
  score            Int?           // AI採点スコア
  feedback         String         // AIフィードバック
  // 解いた問題バンクの問題（カスタム設問はnull）。スコア推移・再提出のグルーピングに使う
  questionBankId   String?
  questionBank     QuestionBank?  @relation(fields: [questionBankId], references: [id], onDelete: SetNull)
  // 面接の深掘り（2ターン目以降）の親記録
  parentRecordId   String?
  parentRecord     PracticeRecord? @relation("PracticeFollowUp", fields: [parentRecordId], references: [id], onDelete: SetNull)
  followUps        PracticeRecord[] @relation("PracticeFollowUp")
  // 生徒/講師による非表示（ソフトデリート。物理削除はしない）
  isArchived       Boolean        @default(false)
  createdAt        DateTime       @default(now())

  @@index([studentProfileId])
  @@index([studentProfileId, questionBankId])
}

// 保護者向けの閲覧専用共有トークン。
// URLを知っている人だけが進捗サマリー（連絡先・答案本文・添削本文は含まない）を閲覧できる。
model SharedAccessToken {
  id               String         @id @default(cuid())
  token            String         @unique // 推測不能なランダム値
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  createdByUserId  String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime       @default(now())

  @@index([studentProfileId])
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int      @default(0)
  lessons     Lesson[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lesson {
  id          String       @id @default(cuid())
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  content     String       @db.Text
  overview    String?      @db.Text
  order       Int          @default(0)
  steps       LessonStep[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([courseId])
}

model LessonStep {
  id          String       @id @default(cuid())
  lessonId    String
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title       String
  description String       @db.Text
  prompt      String       @db.Text
  hint        String?      @db.Text
  placeholder String?      @db.Text
  goodExample String?      @db.Text
  goodReason  String?      @db.Text
  badExample  String?      @db.Text
  badReason   String?      @db.Text
  order       Int          @default(0)
  isRequired  Boolean      @default(true)
  answers     StepAnswer[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([lessonId])
}

model StepAnswer {
  id               String          @id @default(cuid())
  stepId           String
  step             LessonStep      @relation(fields: [stepId], references: [id], onDelete: Cascade)
  studentProfileId String
  studentProfile   StudentProfile  @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  content          String          @db.Text
  feedbacks        AIFeedback[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([stepId, studentProfileId])
  @@index([studentProfileId])
}

model AIFeedback {
  id           String     @id @default(cuid())
  stepAnswerId String
  stepAnswer   StepAnswer @relation(fields: [stepAnswerId], references: [id], onDelete: Cascade)
  content      String     @db.Text
  score        Int?
  createdAt    DateTime   @default(now())

  @@index([stepAnswerId])
}

model QuestionBank {
  id                String   @id @default(cuid())
  tenantId          String?  // null = 全テナント共通（運営提供）。値あり = そのテナント専用（AI生成問題など）
  category          String
  title             String
  prompt            String   @db.Text
  source            String   @default("MANUAL") // "MANUAL" / "AI_GENERATED" / "NOTEBOOKLM" / "CUSTOM"
  university        String?  // 過去問傾向の対象大学（AI生成時）
  fieldCategory     String?  // 正規化済み系統ラベル（field-category.tsの10系統）
  status            String   @default("ACTIVE") // "ACTIVE" / "PENDING"(承認待ち) / "ARCHIVED"(非表示)
  createdByUserId   String?  // 追加したユーザーID（生徒投稿の承認判断・監査用）
  followUpQuestions String?  @db.Text // 面接の深掘り質問（1行1問。modelAnswerから分離）
  difficulty        String?  // 難易度（基礎/標準/発展など）
  modelAnswer       String?  @db.Text // 模範解答の要点・採点ポイント（メンター/採点参照用）
  practiceRecords   PracticeRecord[]
  tasks             Task[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([category, status])
}
